{
  "name": "komektes",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "bun run build && vite preview",
    "test": "vitest run",
    "auth:generate": "bunx auth generate --config ./src/lib/auth.ts --output src/db/auth-schema.ts -y",
    "db:generate": "drizzle-kit generate",
    "db:studio:local": "drizzle-kit studio --config drizzle.config.local.ts",
    "db:studio:remote": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply komektes-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply komektes-db --remote",
    "db:seed:generate": "bun run scripts/seed.ts",
    "db:seed:local": "bun run scripts/seed.ts && wrangler d1 execute komektes-db --local --file=scripts/seed.sql",
    "db:seed:remote": "bun run scripts/seed.ts && wrangler d1 execute komektes-db --remote --file=scripts/seed.sql",
    "db:seed:remove:local": "wrangler d1 execute komektes-db --local --command \"DELETE FROM user WHERE id LIKE 'seed_user_%';\"",
    "db:seed:remove:remote": "wrangler d1 execute komektes-db --remote --command \"DELETE FROM user WHERE id LIKE 'seed_user_%';\"",
    "types": "wrangler types",
    "deploy": "bun install && bun run build && wrangler deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth/drizzle-adapter": "^1.6.5",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-router-ssr-query": "^1.166.11",
    "@tanstack/react-start": "^1.167.42",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-haptics": "^0.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.33.0",
    "@cloudflare/workers-types": "^4.20260421.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.22",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.3.1",
    "tailwindcss": "^4.2.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.0"
  }
}
